{
  "name": "strong_gate",
  "description": "Broad gate: correctness fuzz + hard scaling + max-N dense runs.",
  "stages": [
    {
      "name": "correctness_fuzz",
      "modes": [
        "comb_rect_dense",
        "multi_comb_rect",
        "multi_comb_cap",
        "chain_unary",
        "star_pairs",
        "balanced_dense",
        "broom_mixed",
        "caterpillar_rect_dense",
        "random_recursive_mixed"
      ],
      "sizes": [64, 128, 256, 512, 1024],
      "seeds": [1, 2, 3, 4, 5],
      "shuffle_labels": [0, 1],
      "shuffle_queries": [0, 1],
      "timeout": 2.0,
      "must_pass": true
    },
    {
      "name": "hard_scaling",
      "modes": [
        "comb_core",
        "comb_plus_unary",
        "comb_dense",
        "comb_rect_dense",
        "multi_comb_core",
        "multi_comb_rect",
        "multi_comb_cap",
        "caterpillar_mixed",
        "caterpillar_rect_dense"
      ],
      "sizes": [4096, 8192, 16384, 32768],
      "seeds": [1, 2, 3],
      "shuffle_labels": [1],
      "shuffle_queries": [1],
      "timeout": 12.0,
      "must_pass": true,
      "alpha_max": 1.45,
      "ratio_max": 2.90
    },
    {
      "name": "max_n_mix",
      "modes": [
        "balanced_dense",
        "random_recursive_mixed",
        "comb_dense",
        "comb_rect_dense",
        "multi_comb_rect",
        "multi_comb_cap",
        "caterpillar_rect_dense"
      ],
      "sizes": [50000, 99999],
      "seeds": [1, 2],
      "shuffle_labels": [1],
      "shuffle_queries": [1],
      "timeout": 6.0,
      "must_pass": true
    }
  ]
}
