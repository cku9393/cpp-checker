+        const auto &nodeA = core.nodes[arc.a];
+        const auto &nodeB = core.nodes[arc.b];
+        if (!validCoreSlot(nodeA, arc.slotInA) || !validCoreSlot(nodeB, arc.slotInB)) {
+            why = "actual arc: live arc endpoint slot index invalid";
+            return false;
